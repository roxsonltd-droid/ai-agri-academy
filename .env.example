# --- PostgreSQL (docker-compose) — виж docs/POSTGRES.md ---
# DATABASE_URL=postgresql+psycopg2://agro:agro_dev_change_me@localhost:5432/agro_academy
# Управлявана база (SSL): ...?sslmode=require

# --- Clerk (frontend + backend verify) ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_ENFORCE=false
# CLERK_JWKS_URL=https://<your-subdomain>.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER=https://<your-subdomain>.clerk.accounts.dev
# CLERK_JWT_AUDIENCE=  # по избор, ако валидирате aud

# --- Pinecone + LlamaIndex (виж docs/LANGCHAIN_VECTOR_DB.md) ---
# PLATFORM_RAG_BACKEND=llamaindex
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=agro-academy
# OPENAI_API_KEY=

# --- Бъдещо: Weaviate + LangChain ---
# PLATFORM_RAG_BACKEND=weaviate
# WEAVIATE_URL=
# WEAVIATE_API_KEY=

# --- Cloudflare Stream ---
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_STREAM_API_TOKEN=
# Вижте docs/CLOUDFLARE_STREAM.md за direct upload и playback.

# --- Cloudflare R2 (S3-съвместимо object storage; presign API още не е в кода) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=https://<bucket>.<accountid>.r2.cloudflarestorage.com  # или custom public URL
# R2_PRESIGN_EXPIRES_SECONDS=900
# R2_DELETE_AFTER_INGEST=true
# Вижте docs/CLOUDFLARE_R2.md за потока качване → R2 → Postgres → RAG.

# --- ElevenLabs (TTS) — виж docs/ELEVENLABS_VOICE.md ---
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# VOICE_TTS_MAX_CHARS=4000
# VOICE_TTS_SECRET=  # опционално: X-Voice-TTS-Secret за сървърни job-ове

# --- Roboflow (vision / CV inference) — виж docs/ROBOFLOW_VISION.md ---
# ROBOFLOW_API_KEY=
# ROBOFLOW_WORKSPACE=
# ROBOFLOW_PROJECT=
# ROBOFLOW_VERSION=1
# ROBOFLOW_CONFIDENCE=0.4
# ROBOFLOW_IMAGE_MAX_BYTES=5242880
# ROBOFLOW_SERVERLESS_BASE=https://serverless.roboflow.com
# ROBOFLOW_INFER_SECRET=  # опционално: X-Roboflow-Infer-Secret
